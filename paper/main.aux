\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces KG cleaning evaluation (200 triples: 100 noise + 100 clean) and $\tau $ sensitivity (5 pairs). Two cleaning modes offer a configurable precision--recall tradeoff; $\tau $ sweep confirms ComplEx scores are unhelpful on noisy KGs.\relax }}{7}{table.caption.34}\protected@file@percent }
\newlabel{tab:cleaning_tau}{{5}{7}{KG cleaning evaluation (200 triples: 100 noise + 100 clean) and $\tau $ sensitivity (5 pairs). Two cleaning modes offer a configurable precision--recall tradeoff; $\tau $ sweep confirms ComplEx scores are unhelpful on noisy KGs.\relax }{table.caption.34}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces KG cleaning analysis. (a)--(b) Confusion matrices for conservative and aggressive modes. (c) Precision, recall, and F1 comparison: conservative mode achieves high precision (0.83); aggressive mode achieves perfect recall (1.0).\relax }}{7}{figure.caption.35}\protected@file@percent }
\newlabel{fig:cleaning}{{4}{7}{KG cleaning analysis. (a)--(b) Confusion matrices for conservative and aggressive modes. (c) Precision, recall, and F1 comparison: conservative mode achieves high precision (0.83); aggressive mode achieves perfect recall (1.0).\relax }{figure.caption.35}{}}
